SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=postgresql+psycopg://postgres:YOUR_DATABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
REDIS_URL=redis://localhost:6379/0
AUTH_REQUIRED=true
BACKEND_CORS_ORIGINS=https://ai-commerce-os-demo.ybqes.chatgpt.site,https://ai-commerce-os-internal.ybqes.chatgpt.site,http://localhost:3000,http://127.0.0.1:3000
MERCHANT_BRIDGE_API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
MERCHANT_BRIDGE_COMPANY_ID=00000000-0000-0000-0000-000000000001
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
TOKEN_ENCRYPTION_KEY=
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_REDIRECT_URI=https://YOUR_API_DOMAIN/v1/connectors/taobao/oauth/callback
DOUYIN_APP_KEY=
DOUYIN_APP_SECRET=
DOUYIN_AUTHORIZATION_URL=
DOUYIN_REDIRECT_URI=https://YOUR_API_DOMAIN/v1/connectors/douyin/oauth/callback

# 直播 Workflow 日志存储模式：默认 memory。表结构确认并执行 migration 后才改 postgres。
LIVE_WORKFLOW_LOG_STORAGE=memory

# Boss approval records storage mode. Keep memory locally; switch to postgres after running approval_records migration.
APPROVAL_RECORD_STORAGE=memory

# After-sale approval decision outcome storage. Keep memory locally; switch to postgres after running after_sale_decision_outcomes migration.
AFTER_SALE_DECISION_STORAGE=memory

# CEO daily report evidence snapshots. Switch to postgres after running the CEO snapshot migration.
CEO_REPORT_SNAPSHOT_STORAGE=memory

# Warehouse notification delivery. export_queue marks queued replacement notices as sent to the ERP/WMS export queue.
WAREHOUSE_NOTIFICATION_DELIVERY_MODE=export_queue
WAREHOUSE_NOTIFICATION_EXPORT_PREFIX=wms-export# Switch WAREHOUSE_NOTIFICATION_DELIVERY_MODE=http_api after the WMS/ERP endpoint is ready.
WAREHOUSE_NOTIFICATION_WMS_API_URL=
WAREHOUSE_NOTIFICATION_WMS_API_KEY=
WAREHOUSE_NOTIFICATION_WMS_TIMEOUT_SECONDS=10